{
  "name": "promptgrid-server",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": "24.x"
  },
  "scripts": {
    "dev": "node --watch src/index.js",
    "dev:memory": "node scripts/memory-server.js",
    "seed:admin": "node scripts/seed-admin.js",
    "seed:prompts": "node scripts/seed-prompts.js",
    "migrate:database": "node scripts/migrate-database.js",
    "start": "node src/index.js",
    "lint": "eslint src tests scripts",
    "test": "vitest run --fileParallelism=false",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "@emnapi/core": "^1.11.1",
    "@emnapi/runtime": "^1.11.1",
    "@eslint/js": "^10.0.1",
    "eslint": "^10.5.0",
    "globals": "^17.6.0",
    "mongodb-memory-server": "^11.2.0",
    "supertest": "^7.2.2",
    "vitest": "^4.1.9"
  },
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "cloudinary": "^2.10.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "express-rate-limit": "^8.5.2",
    "google-auth-library": "^10.7.0",
    "helmet": "^8.2.0",
    "jsonwebtoken": "^9.0.3",
    "mongoose": "^9.7.1",
    "multer": "^2.2.0",
    "stripe": "^22.2.1",
    "zod": "^4.4.3"
  }
}
